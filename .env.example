# Copy this to .env and fill in your values.
# .env is git-ignored — never commit real secrets.

# Shared secret between the local tradebot engine and the Railway webapp.
# Must match the TRADEBOT_KEY variable set in Railway → Variables.
TRADEBOT_KEY=your_secret_here

# The public Railway URL for your webapp
WEBAPP_URL=https://tradebot-production-c63c.up.railway.app
