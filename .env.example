# ============================================================
#  tradebot / .env.example
#  Copy this to .env and fill in your values.
#  .env is git-ignored — never commit real secrets.
#
#  Usage:
#    cp .env.example .env
#    # Edit .env with your actual values
#    # Python: python-dotenv loads these automatically
# ============================================================

# ── Railway web app ─────────────────────────────────────────
# Your live Railway dashboard URL
WEBAPP_URL=https://tradebot-production-c63c.up.railway.app

# Secret key — must match TRADEBOT_KEY in Railway → Variables
TRADEBOT_KEY=your_secret_key_here

# ── Angel One SmartAPI ───────────────────────────────────────
# Get from: smartapi.angelone.in → your app → API Key
ANGEL_API_KEY=your_angel_one_api_key

# Your Angel One client ID (login ID)
ANGEL_CLIENT_ID=your_client_id

# Your 4-digit trading PIN (not your login password)
ANGEL_PIN=your_4_digit_pin

# Base32 TOTP secret from Angel One mobile app
# Profile → Security → Enable TOTP → "Can't scan?" → copy the string
ANGEL_TOTP_SECRET=your_base32_totp_secret

# ── Telegram alerts (optional) ───────────────────────────────
# Create bot via @BotFather → /newbot → get token
TELEGRAM_TOKEN=your_telegram_bot_token

# Your Telegram chat ID
# Visit: https://api.telegram.org/bot<TOKEN>/getUpdates after messaging your bot
TELEGRAM_CHAT_ID=your_chat_id

# ── Active broker ────────────────────────────────────────────
# paper | zerodha | shoonya | angel | fyers
ACTIVE_BROKER=paper

# Data source (angel = free, no subscription)
DATA_SOURCE=angel
